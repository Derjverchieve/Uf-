<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@color/background"
    android:padding="32dp"
    tools:context=".activities.BlockedAppActivity">

    <ImageView
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:src="@drawable/ic_phone_addiction"
        android:contentDescription="@string/addiction_image"
        android:layout_marginBottom="28dp"
        android:alpha="0.85"/>

    <!-- Red accent line -->
    <View
        android:layout_width="40dp"
        android:layout_height="3dp"
        android:background="@color/locked_red"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:id="@+id/titleTextView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/hold_on"
        android:textStyle="bold"
        android:textSize="30sp"
        android:textColor="@color/text_primary"
        android:layout_marginBottom="10dp"/>

    <TextView
        android:id="@+id/messageTextView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Take a short break.\nLet your mind rest and do something offline.\nYou've got this!"
        android:textSize="15sp"
        android:textColor="@color/text_secondary"
        android:gravity="center"
        android:lineSpacingMultiplier="1.4"
        android:layout_marginBottom="40dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnBackToFocus"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="@string/back_to_focus_mode"
        android:textSize="15sp"
        style="@style/Widget.Material3.Button.OutlinedButton"/>



</LinearLayout>
