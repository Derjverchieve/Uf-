<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/material_dynamic_neutral10"
    android:padding="16dp">

    <!-- Title -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Advanced Blocker"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@android:color/black"
        android:layout_marginBottom="16dp"/>

    <!-- Tabs -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <Button
            android:id="@+id/btnTabScreens"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Screens"
            android:layout_marginEnd="4dp"/>

        <Button
            android:id="@+id/btnTabKeywords"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Keywords"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"/>

        <Button
            android:id="@+id/btnTabWeb"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Web"
            android:layout_marginStart="4dp"/>
    </LinearLayout>

    <!-- Debug -->
    <CheckBox
        android:id="@+id/chkDebug"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Debug Mode (Show Class Names)"
        android:layout_marginBottom="8dp"/>

    <!-- 🔥 Web Mode Toggle (RESTORED) -->
    <Switch
        android:id="@+id/switchWebMode"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Specific Mode (Allow only selected pages)"
        android:layout_marginBottom="8dp"/>

    <!-- Download Block -->
    <Switch
        android:id="@+id/switchDownloadBlock"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Block Downloads in Downloads folder"
        android:layout_marginBottom="8dp"/>

    <!-- Permission -->
    <Button
        android:id="@+id/btnGrantAllFiles"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Grant All Files Access"
        android:layout_marginBottom="8dp"/>

    <!-- Export -->
    <Button
        android:id="@+id/btnExportSettings"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Export Settings"
        android:layout_marginBottom="4dp"/>

    <!-- Import -->
    <Button
        android:id="@+id/btnImportSettings"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Import Settings"
        android:layout_marginBottom="8dp"/>

    <!-- List -->
    <ListView
        android:id="@+id/listView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:dividerHeight="1dp"
        android:background="@android:color/white"/>

    <!-- Add Button -->
    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/fabAdd"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Add New"
        android:layout_gravity="end"
        android:layout_marginTop="16dp"
        android:backgroundTint="@color/design_default_color_primary"/>
</LinearLayout>
