<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="0dp"
    android:layout_marginVertical="4dp"
    app:cardBackgroundColor="@color/surface"
    app:cardCornerRadius="14dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/card_stroke"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingVertical="10dp"
        android:paddingStart="12dp"
        android:paddingEnd="6dp">

        <!-- App icon -->
        <androidx.cardview.widget.CardView
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:layout_marginEnd="12dp"
            app:cardElevation="0dp"
            app:cardCornerRadius="10dp">
            <ImageView
                android:id="@+id/icon"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="fitCenter"/>
        </androidx.cardview.widget.CardView>

        <!-- Name + schedule -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_weight="1">

            <TextView
                android:id="@+id/label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="App Name"
                android:textSize="15sp"
                android:textColor="@color/text_primary"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/timePeriodInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="11sp"
                android:textColor="@color/text_secondary"
                android:visibility="gone"
                android:layout_marginTop="2dp"/>

        </LinearLayout>

        <!-- Soft block toggle (shield) -->
        <ImageButton
            android:id="@+id/btnSoftBlock"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:src="@drawable/ic_shield"
            app:backgroundTint="@android:color/transparent"
            android:contentDescription="Toggle soft block"
            android:padding="7dp"/>

        <!-- Delete -->
        <ImageButton
            android:id="@+id/delete"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:src="@drawable/ic_delete"
            app:backgroundTint="@android:color/transparent"
            android:contentDescription="Remove app"
            android:padding="7dp"/>

        <!-- Timer / schedule -->
        <ImageButton
            android:id="@+id/btnSetTimePeriod"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:src="@drawable/ic_timer_outline"
            app:backgroundTint="@android:color/transparent"
            android:contentDescription="Set schedule"
            android:layout_marginEnd="2dp"
            android:padding="7dp"/>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
